package nl.jinsoo.template.notepad;

import org.junit.jupiter.api.Test;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.test.web.servlet.client.RestTestClient;
import nl.jinsoo.template.testsupport.OpenApiContractValidator;

@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
class NoteEndpointIT {

    @Test
    void getNote(RestTestClient client) {
        var result = client.get().uri("/api/notes/1")
            .exchange()
            .expectStatus().isOk()
            .expectBody()
            .returnResult();

        OpenApiContractValidator.assertResponseMatchesSpec(
            "GET", "/api/notes/1", 200, result.getResponseBody(), "application/json");
    }
}
