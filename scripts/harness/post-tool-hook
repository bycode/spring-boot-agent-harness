#!/usr/bin/env bash
# Combined PostToolUse hook for Edit/Write/Bash.
# Thin dispatcher: parses the tool input JSON once, exports the dispatcher
# contract vars, invokes every check in CHECKS, merges each chunk into a
# single additionalContext value, and emits one JSON object.
# Non-blocking (exit 0). Check logic lives in scripts/harness/lib/hook-checks.sh.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/hook-checks.sh
. "$SCRIPT_DIR/lib/hook-checks.sh"

INPUT=$(cat)
# Single jq call parses all three fields in one invocation, emitting each on
# its own line. Three sequential `read`s pull the fields from the same pipe.
# (Using IFS=$'\t' + read would coalesce empty fields because tab is an IFS
# whitespace char in bash; newline-separated output avoids that.)
{
  read -r TOOL
  read -r FILE
  read -r CMD
} < <(
  printf '%s' "$INPUT" \
    | jq -r '.tool_name // "", .tool_input.file_path // "", .tool_input.command // ""'
)
REPO_ROOT="${REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

export TOOL FILE CMD INPUT REPO_ROOT

# Ordered list of check functions. Add new checks here when extending the library.
CHECKS=(
  check_test_reminder
  check_plan_progress
  check_test_naming
  check_deprecated_test_api
  check_contract_validator_in_it
  check_lombok_denylist
  check_style_scan
  check_session_block_structure
  check_openapi_annotations_present
  check_jacoco_config_guard
)

CONTEXT=""
for check in "${CHECKS[@]}"; do
  chunk=$("$check" || true)
  if [[ -n "$chunk" ]]; then
    CONTEXT="${CONTEXT:+$CONTEXT\n\n}$chunk"
  fi
done

if [[ -n "$CONTEXT" ]]; then
  jq -nc --arg ctx "$CONTEXT" '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":$ctx}}'
fi
