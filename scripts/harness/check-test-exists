#!/usr/bin/env bash
# PostToolUse hook: remind about test coverage for every production Java file.
# Non-blocking (exit 0) — injects context, doesn't gate.

set -euo pipefail

INPUT=$(cat)
FILE=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)

[[ -z "$FILE" ]] && exit 0
[[ "$FILE" != *src/main/java/*.java ]] && exit 0

BASENAME=$(basename "$FILE" .java)
[[ "$BASENAME" == "package-info" ]] && exit 0

printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"TEST REMINDER: You wrote %s. Decide what test this needs (unit, slice, or integration) per .claude/rules/testing.md, if a test is needed do NOT delay writing it, do it right now"}}\n' "$BASENAME"
