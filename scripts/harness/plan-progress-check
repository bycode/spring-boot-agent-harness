#!/usr/bin/env bash
# PostToolUse hook (Bash|Edit|Write): enforce plan progress updates.
# Non-blocking (exit 0) — injects context warnings, doesn't gate.

set -euo pipefail

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty')
CMD=$(echo "$INPUT" | jq -r '.tool_input.command // empty')

# For Bash: only trigger on build/verification commands
if [ "$TOOL" = "Bash" ]; then
  echo "$CMD" | grep -qE 'mvnw|full-check|verify|spotless|smoke-startup|doc-lint|fast-check' || exit 0
fi
# Edit/Write: always trigger (they indicate active code work)

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
MSG=''

for plan in "$REPO_ROOT"/docs/exec-plans/active/*.md; do
  [ -e "$plan" ] || continue
  NAME=$(basename "$plan")

  OPEN=$(grep -c '^- \[ \]' "$plan" 2>/dev/null || true)
  IN_PROGRESS=$(grep -c '^- \[~\]' "$plan" 2>/dev/null || true)
  DONE=$(grep -c '^- \[x\]' "$plan" 2>/dev/null || true)

  # Warn: tests passed but step still marked in-progress (Bash only)
  if [ "$TOOL" = "Bash" ] && [ "$IN_PROGRESS" -gt 0 ] && echo "$CMD" | grep -qE 'verify|full-check|test'; then
    TOOL_EXIT=$(echo "$INPUT" | jq -r '.tool_result.exit_code // empty')
    if [ "$TOOL_EXIT" = "0" ]; then
      MSG="$MSG  ⚠️ $NAME: Tests passed with step still [~]. Mark it [x] and add execution notes before continuing.\n"
    fi
  fi

  # Warn: work happening but no step marked in-progress
  if [ "$IN_PROGRESS" -eq 0 ] && [ "$OPEN" -gt 0 ]; then
    MSG="$MSG  🚫 $NAME: No step marked [~] in-progress. Mark your current step [~] in the plan file NOW before writing more code.\n"
  fi

  # Warn: plan exceeds 8-step limit
  TOTAL=$((OPEN + IN_PROGRESS + DONE))
  if [ "$TOTAL" -gt 12 ]; then
    MSG="$MSG  🚫 $NAME: $TOTAL steps exceeds 12-step limit. Split into an epic with child plans (see exec-plans.md § \"Plan size limit\").\n"
  fi

  # Status line
  if [ "$OPEN" -gt 0 ]; then
    MSG="$MSG  📋 $NAME: $DONE done, $IN_PROGRESS active, $OPEN remaining\n"
  elif [ "$DONE" -gt 0 ]; then
    MSG="$MSG  ✅ $NAME: All items checked — move to docs/exec-plans/completed/\n"
  fi
done

if [ -n "$MSG" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"EXEC PLAN CHECKPOINT:\\n%s"}}\n' "$MSG"
fi
